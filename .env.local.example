# Convex — set automatically by `npx convex dev`
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Convex Auth — set in the Convex dashboard under Settings > Environment Variables
# Create OAuth credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Generate with: openssl rand -base64 32
JWKS=
JWT_PRIVATE_KEY=
